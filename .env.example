# Required (at least one LLM provider)
OPENAI_API_KEY=your-openai-api-key-here

# LLM Provider: "openai" (default, paid), "gemini" (free tier), "groq" (free tier)
LLM_PROVIDER=openai

# Free alternatives (set LLM_PROVIDER to use these)
# GOOGLE_API_KEY=your-google-api-key-here    # For Gemini 2.0 Flash (free: 1500 req/day)
# GROQ_API_KEY=your-groq-api-key-here        # For Llama 3.3 70B (free: 30 RPM)

# Tracing (optional)
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=call-center-intelligence
LANGCHAIN_TRACING_V2=true

# Database
DB_ENCRYPTION_KEY=your-32-byte-hex-key-here
DB_PATH=data/calls.db

# Rate Limiting
MAX_COST_PER_CALL_USD=2.00
MAX_RETRIES_PER_NODE=3
LLM_TIMEOUT_SECONDS=30

# Audio Processing
# Model sizes: tiny, tiny.en, base, base.en, small, small.en, medium, large-v3
# "tiny" is default (fastest, good for clear English). Use "base" or "small" for better accuracy.
# Use "large-v3" with GPU for best accuracy.
WHISPER_MODEL_SIZE=tiny
CONFIDENCE_THRESHOLD=0.6
LOW_CONFIDENCE_HALT_RATIO=0.4
